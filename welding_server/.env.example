# WeldVision-X5 Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# CLOUDFLARE WORKER (cloud_worker/)
# =============================================================================

# Cloudflare account & zone
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# JWT signing secret (generate a strong random string)
JWT_SECRET=change-this-to-a-secure-random-string

# Worker AI model binding (set in wrangler.toml — no value needed here)
# AI binding is declared in wrangler.toml under [ai]

# =============================================================================
# RDK X5 EDGE DEVICE
# =============================================================================

RDK_IP=192.168.1.100
RDK_USERNAME=sunrise
RDK_PASSWORD=sunrise

# =============================================================================
# OPTIONAL: CLOUD TRAINING (if using external services)
# =============================================================================

# Roboflow API Key (for dataset sync)
# ROBOFLOW_API_KEY=your-api-key

# Ultralytics HUB API Key
# ULTRALYTICS_API_KEY=your-api-key
